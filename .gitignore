# Python bytecode/cache
*.pyc
*.pyo
*.pyd
*.pdf
__pycache__/

# Explicitly ignore cache under script
script/__pycache__/
script/**/__pycache__/

# LoCoMo benchmark local data artifacts (ignore all files under data/)
benchmark/locomo/data/**

# LongMemEval local data artifacts (ignore all files under data/)
benchmark/longmemeval/data/**
